{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.nx/**": true,
    "**/docker/docker_data/**": true,
    "**/coverage/**": true,
    "**/*.log": true,
    "**/*.lock": true,
    "**/*.wt": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.nx": true,
    "**/docker/docker_data": true,
    "**/coverage": true,
    "**/*.log": true,
    "**/*.lock": true,
    "**/*.wt": true
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "chat.tools.terminal.autoApprove": {
    "npx nx": true,
    "/^cat ~/\\.vscode/extensions/nrwl\\.angular-console\\*/package\\.json \\| python3 -c \"import json,sys; d=json\\.load\\(sys\\.stdin\\); vc=d\\.get\\('contributes',\\{\\}\\)\\.get\\('viewsContainers',\\{\\}\\); print\\(json\\.dumps\\(vc, indent=2\\)\\)\" 2>/dev/null$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
